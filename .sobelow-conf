[
  verbose: false,
  private: false,
  skip: false,
  router: "",
  exit: "Low",
  format: "txt",
  out: "",
  threshold: "low",
  # Misc.BinToTerm: Storage.Local persists with term_to_binary and reads
  #   back with binary_to_term(_, [:safe]). Input comes from the device's
  #   own filesystem (operator-controlled), not the network, and the
  #   :safe flag refuses unknown atoms / fun references.
  # DOS.StringToAtom: Telemetry stream names come from the signed
  #   contract bundle (verified before any String.to_atom call), not
  #   arbitrary network input. Bundle authoring is operator-controlled.
  ignore: ["Traversal.FileModule", "Misc.BinToTerm", "DOS.StringToAtom"],
  ignore_files: [],
  details: nil,
  all_details: nil,
  mark_skip_all: nil,
  clear_skip: nil
]
